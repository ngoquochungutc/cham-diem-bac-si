{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/public/api/(.*)", "destination": "/api/index.php" },
    { "source": "/api/(.*)", "destination": "/api/index.php" },
    { "source": "/((?!api|public|frontend).*)" , "destination": "/frontend/index.html" }
  ]
}
